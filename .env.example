# =============================================================================
# Banco de dados
# =============================================================================
POSTGRES_DB=solutions_clinic
POSTGRES_USER=solutions_clinic
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# ==============================================================================
# Backend
# ==============================================================================
BACKEND_PORT=8080

# JWT / Segurança (obrigatório, mínimo 32 caracteres)
SECURITY_TOKEN_SECRET=
SECURITY_JWT_ISSUER=solutions-clinic
SECURITY_JWT_AUDIENCE=
SECURITY_JWT_JWK_SET_URI=

# Stripe
STRIPE_API_KEY=
STRIPE_API_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SUCCESS_PATH=/plan-selection/success
STRIPE_WEBHOOK_CANCEL_PATH=/plan-selection

# WhatsApp
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Memed
MEMED_API_KEY=
MEMED_API_URL=https://integrations.api.memed.com.br/v1
MEMED_SECRET_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

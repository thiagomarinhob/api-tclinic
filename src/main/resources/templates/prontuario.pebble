<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Prontuário</title>
  <style type="text/css">
    @page {
      size: A4;
      margin: 1.5cm;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 11pt;
      color: #000;
      line-height: 1.4;
    }

    .page {
      width: 100%;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
    }

    /* Cabeçalho Superior */
    .header-table td {
      border: none;
      vertical-align: middle;
      padding: 10px;
    }

    .logo-cell {
      width: 120px;
      text-align: center;
    }

    .logo-cell img {
      max-width: 110px;
      max-height: 70px;
    }

    /* Marca d'água */
    .watermark {
      position: fixed;
      top: 28%;
      left: 10%;
      width: 80%;
    }
    .watermark img { width: 100%; height: auto; }

    .clinic-name-header {
      text-align: center;
      font-size: 14pt;
      font-weight: normal;
    }

    .doc-title {
      text-align: center;
      font-size: 13pt;
      font-weight: bold;
      text-transform: uppercase;
      margin: 20px 0;
    }

    /* Tabelas de conteúdo */
    .content-table td {
      border: 1px solid #000;
      padding: 8px 12px;
    }

    .th-gray {
      background-color: #e0e0e0;
      font-weight: bold;
    }

    /* Sinais Vitais */
    .vital-signs-table td {
      border: 1px solid #ccc;
      padding: 5px 10px;
      font-size: 10pt;
    }

    .vital-label {
      font-weight: bold;
      background-color: #f5f5f5;
      width: 40%;
    }

    /* Campos do prontuário */
    .field-block {
      margin-bottom: 0;
    }

    .field-label-cell {
      background-color: #f0f0f0;
      font-weight: bold;
      font-size: 10pt;
      padding: 6px 12px;
      border: 1px solid #000;
      border-bottom: none;
    }

    .field-value-cell {
      white-space: pre-wrap;
      padding: 10px 12px;
      border: 1px solid #000;
      min-height: 40px;
      vertical-align: top;
    }

    /* Rodapé / Assinatura */
    .signature-container {
      margin-top: 50px;
      width: 100%;
    }

    .signature-wrapper {
      float: right;
      width: 320px;
      text-align: center;
    }

    .signature-line {
      border-top: 1px solid #000;
      margin-bottom: 5px;
    }

    .signature-info {
      font-size: 10pt;
      color: #666;
      font-weight: bold;
    }

    .specialty-info {
      font-size: 9pt;
      color: #999;
    }

    .record-id {
      font-size: 8pt;
      color: #aaa;
      margin-top: 4px;
    }

    .clearfix:after {
      content: "";
      display: table;
      clear: both;
    }
  </style>
</head>
<body>
  <div class="page">

    {% if clinicWatermarkBase64 is not null %}
    <div class="watermark">
      <img src="{{ clinicWatermarkBase64 }}" alt="" />
    </div>
    {% endif %}

    <table class="header-table">
      <tr>
        <td class="logo-cell">
          {% if clinicLogoBase64 is not null %}
            <img src="{{ clinicLogoBase64 }}" width="100" height="60" alt="Logo {{ clinicName }}" />
          {% endif %}
        </td>
        <td class="clinic-name-header">{{ clinicName }}</td>
        <td class="logo-cell">
          {% if systemLogoBase64 is not null %}
            <img src="{{ systemLogoBase64 }}" width="100" height="60" alt="Solutions Clinic" />
          {% endif %}
        </td>
      </tr>
    </table>

    <div class="doc-title">Prontuário — {{ templateName }}</div>

    <table class="content-table">
      <tr>
        <td class="th-gray" style="width: 50%;">Paciente</td>
        <td class="th-gray" style="width: 50%;">Data: {{ appointmentDate }}</td>
      </tr>
      <tr>
        <td>{{ patientName }}</td>
        <td>{{ professionalName }}</td>
      </tr>
    </table>

    {% if vitalSigns is not empty %}
    <table class="content-table">
      <tr>
        <td class="th-gray" colspan="2">Sinais Vitais</td>
      </tr>
      {% for item in vitalSigns %}
      <tr>
        <td class="vital-label" style="width: 40%;">{{ item.label }}</td>
        <td>{{ item.value }}</td>
      </tr>
      {% endfor %}
    </table>
    {% endif %}

    {% for field in fields %}
    <table class="content-table" style="margin-bottom: 14px;">
      <tr>
        <td class="th-gray">{{ field.label }}</td>
      </tr>
      <tr>
        <td class="field-value-cell">{{ field.value | default('—') }}</td>
      </tr>
    </table>
    {% endfor %}

    <div class="signature-container clearfix">
      <div class="signature-wrapper">
        <div class="signature-line"></div>
        <div class="signature-info">
          {{ professionalName }}
        </div>
        {% if specialty %}
        <div class="specialty-info">
          {{ specialty }}
        </div>
        {% endif %}
        <div class="record-id">ID: {{ recordId }}</div>
      </div>
    </div>

  </div>
</body>
</html>
